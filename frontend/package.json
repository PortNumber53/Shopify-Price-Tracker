{
	"name": "frontend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "npm run build && concurrently -k -n ui,worker -c green,cyan \"npm run dev:ui\" \"npm run dev:worker\"",
		"dev:ui": "vite",
		"dev:worker": "wrangler dev --port 20912 --ip 0.0.0.0 --local",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"preview": "npm run build && vite preview",
		"deploy": "npm run build && wrangler deploy",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@stripe/react-stripe-js": "^5.6.1",
		"@stripe/stripe-js": "^8.9.0",
		"lucide-react": "^0.577.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-router-dom": "^7.13.1"
	},
	"devDependencies": {
		"concurrently": "^9.1.2",
		"@cloudflare/vite-plugin": "^1.27.0",
		"@eslint/js": "^9.39.1",
		"@types/node": "^24.12.0",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react-swc": "^4.2.2",
		"autoprefixer": "^10.4.27",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"globals": "^16.5.0",
		"postcss": "^8.5.8",
		"tailwindcss": "^4.2.1",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.48.0",
		"vite": "^7.3.1",
		"wrangler": "^4.72.0"
	}
}
